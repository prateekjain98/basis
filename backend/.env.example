# LLM Provider (OpenAI-compatible -- works with Groq, Together, etc.)
OPENAI_API_KEY=sk-...

# Optional: override base URL for faster/cheaper providers
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# Web Search API -- Tavily for institutional-grade search
# Falls back to DuckDuckGo if not set
TAVILY_API_KEY=tvly-...

# LlamaParse / LlamaCloud for PDF parsing
LLAMA_CLOUD_API_KEY=llx-...

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...

# Qdrant (local or cloud)
QDRANT_URL=http://localhost:6333
